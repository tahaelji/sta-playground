        { "from": "CK", "to": "Q", "delay": 160, "sense": "positive_unate" },
        { "from": "D", "to": "D", "delay": 85, "sense": "non_unate", "check": "setup" },
        { "from": "D", "to": "D", "delay": 35, "sense": "non_unate", "check": "hold" }
      ] },
      { "id": "div_flop", "type": "DFFX1", "isSequential": true, "area": 5.8, "pins": [
